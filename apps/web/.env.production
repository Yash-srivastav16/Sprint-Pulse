# ── Supabase (public/anon values — safe to commit) ───────────────────────────
# Supabase project URL
VITE_SUPABASE_URL=https://fgonyjhtrkuiakhbnqev.supabase.co
# Anon/public key — designed for browser use, protected by RLS
VITE_SUPABASE_ANON_KEY=sb_publishable_z7o9VK_Za3-Licb2cpwBNw_ViKFuJAB

# ── API ───────────────────────────────────────────────────────────────────────
# Railway production API URL — all /api/* requests go here
VITE_API_URL=https://sprintpulseapi-production.up.railway.app/api

# ── Feature Flags ─────────────────────────────────────────────────────────────
# Set to true to fetch projects directly from Supabase (bypasses API)
VITE_DIRECT_SUPABASE_PROJECTS=false
# Enable AI-powered sprint insights (requires OPENAI_API_KEY on API side)
VITE_ENABLE_AI_INSIGHTS=true

# ── Timeouts (ms) ─────────────────────────────────────────────────────────────
# Timeout for read/fetch API requests
VITE_PROJECT_API_TIMEOUT_MS=30000
# Timeout for create/update/delete API requests
VITE_PROJECT_MUTATION_TIMEOUT_MS=10000
