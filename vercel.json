{
  "version": 2,
  "installCommand": "npm install",
  "buildCommand": "npm run build -w packages/shared && npm run build -w apps/api && npm run build -w apps/web",
  "outputDirectory": "apps/web/dist",
  "builds": [
    {
      "src": "api/index.ts",
      "use": "@vercel/node",
      "config": {
        "includeFiles": ["apps/api/src/**", "packages/shared/**"]
      }
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/index.ts" },
    { "src": "/favicon.ico", "dest": "/api/index.ts" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
