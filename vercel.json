{
  "version": 2,
  "installCommand": "npm install",
  "buildCommand": "npm run build -w packages/shared && npm run build -w apps/web",
  "outputDirectory": "apps/web/dist",
  "functions": {
    "api/index.ts": {
      "includeFiles": "apps/api/src/**,packages/shared/src/**,packages/shared/package.json"
    }
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/index.ts" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
